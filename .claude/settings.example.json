{
  "model": "claude-sonnet",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(git status)",
      "Bash(git diff --stat)",
      "Bash(cargo test:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git reset --hard)",
      "Bash(git clean -fdx)"
    ]
  },
  "notes": [
    "Prefer small vertical slices",
    "Read CLAUDE.md before major work",
    "Do not bypass domain contracts"
  ]
}
