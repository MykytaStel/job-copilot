{
  "title": "Job Copilot - Engine API",
  "uid": "engine-api-overview",
  "schemaVersion": 36,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Response Time by Endpoint (P50/P95/P99)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 16,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate({__name__=~\"http_request_duration_seconds_bucket|axum_http_requests_duration_seconds_bucket\"}[5m])) by (le, endpoint))",
          "legendFormat": "p50 {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate({__name__=~\"http_request_duration_seconds_bucket|axum_http_requests_duration_seconds_bucket\"}[5m])) by (le, endpoint))",
          "legendFormat": "p95 {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate({__name__=~\"http_request_duration_seconds_bucket|axum_http_requests_duration_seconds_bucket\"}[5m])) by (le, endpoint))",
          "legendFormat": "p99 {{endpoint}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Top 5 Slowest Endpoints (P95)",
      "type": "table",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "topk(5, histogram_quantile(0.95, sum(rate({__name__=~\"http_request_duration_seconds_bucket|axum_http_requests_duration_seconds_bucket\"}[5m])) by (le, endpoint)))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Rate by Endpoint (req/s)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate({__name__=~\"http_request_duration_seconds_count|axum_http_requests_duration_seconds_count\"}[1m])) by (method, endpoint)",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error Rate by Endpoint (4xx/5xx)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate({__name__=~\"http_request_duration_seconds_count|axum_http_requests_duration_seconds_count\", status_code=~\"4..|5..\"}[1m])) by (endpoint, status_code)",
          "legendFormat": "{{status_code}} {{endpoint}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Request Duration Heatmap",
      "type": "heatmap",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate({__name__=~\"http_request_duration_seconds_bucket|axum_http_requests_duration_seconds_bucket\"}[5m])) by (le)",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Status Code Breakdown",
      "type": "piechart",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (status_code) (increase({__name__=~\"http_request_duration_seconds_count|axum_http_requests_duration_seconds_count\"}[5m]))",
          "legendFormat": "{{status_code}}"
        }
      ]
    }
  ]
}
