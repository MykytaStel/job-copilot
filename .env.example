APP_ENV=development

PORT=8080
DATABASE_URL=postgres://jobcopilot:jobcopilot@127.0.0.1:5432/jobcopilot
DATABASE_MAX_CONNECTIONS=5
RUN_DB_MIGRATIONS=true

JWT_SECRET=replace-me-for-local-dev
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

ML_SIDECAR_BASE_URL=http://localhost:8000
ML_SIDECAR_TIMEOUT_SECONDS=90
ML_RETRAIN_THRESHOLD=15
ML_RETRAIN_POLL_INTERVAL_SECONDS=21600

RERANKER_RUNTIME_MODE=deterministic
LEARNED_RERANKER_ENABLED=true
TRAINED_RERANKER_ENABLED=false
TRAINED_RERANKER_MODEL_PATH=

METRICS_PORT=9090